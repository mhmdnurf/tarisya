TARISYA_SERVER_ID=srv_prod_01
TARISYA_API_KEY=replace-with-server-api-key
TARISYA_CORE_URL=http://localhost:8081/api/v1/metrics
TARISYA_INTERVAL=15s
TARISYA_HTTP_TIMEOUT=10s
TARISYA_DISK_PATH=/

# Tarisya Core
TARISYA_CORE_ADDRESS=:8081
TARISYA_DATABASE_URL=postgres://tarisya:tarisya@localhost:5432/tarisya?sslmode=disable
TARISYA_JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
TARISYA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TARISYA_COOKIE_SECURE=false
TARISYA_OFFLINE_THRESHOLD=90s
TARISYA_WARNING_THRESHOLD=80
TARISYA_CRITICAL_THRESHOLD=90
TARISYA_BOOTSTRAP_SERVER_ID=srv_prod_01
TARISYA_BOOTSTRAP_API_KEY=replace-with-server-api-key
TARISYA_BOOTSTRAP_USER_NAME=Development User
TARISYA_BOOTSTRAP_USER_EMAIL=dev@tarisya.local
TARISYA_BOOTSTRAP_USER_PASSWORD=development-password
